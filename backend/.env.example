# ==========================================
# SyncOps Backend Environment Configuration
# ==========================================

# Server Configuration
NODE_ENV=development
PORT=5002

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long
JWT_EXPIRES_IN=7d

# OTP Configuration
OTP_EXPIRY_MINUTES=10
DEV_OTP=123456

# ==========================================
# Fast2SMS Configuration (for SMS OTP)
# ==========================================
# Get API key from: https://www.fast2sms.com/dashboard
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ==========================================
# EmailJS Configuration (for INVITATION EMAILS ONLY)
# ==========================================
# Used only for sending invitation codes to new team members
# OTP is sent via SMS (Fast2SMS), not email
#
# 1. Create account at: https://www.emailjs.com/
# 2. Add Email Service (Gmail/Outlook/Custom SMTP)
# 3. Create INVITE template (copy from email-templates/invite-email.html)
# 4. Get Public Key from Account > API Keys
# 5. Get Private Key from Account > API Keys (Server-side only)

EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID_INVITE=your_invite_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key

# Frontend URL (for CORS + invite links)
# For multiple origins (local + production), use comma-separated values:
# FRONTEND_URL=http://localhost:5173,https://your-app.netlify.app
FRONTEND_URL=http://localhost:5173

# ==========================================
# Cloudinary (Media Storage - Images & Audio)
# ==========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==========================================
# AES-256 Message Encryption
# ==========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). Keep this SECRET — changing it breaks old messages.
ENCRYPTION_KEY=your_64_char_hex_key_here

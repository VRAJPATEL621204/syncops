generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Role enum aligned with project specs: Admin, Manager, Employee
enum Role {
  admin
  manager
  employee
}

enum IncidentPriority {
  low
  medium
  high
  critical
}

enum IncidentStatus {
  report_pending
  rejected
  open
  in_progress
  resolved
  closed
}

enum IncidentCategory {
  bug
  feature_request
  incident
  security
  performance
  other
}

enum IncidentLogAction {
  report_created
  report_approved
  report_rejected
  created
  status_changed
  priority_changed
  team_assigned
  manager_assigned
  participants_added
  resolved
  closed
  reopened
  description_updated
  title_updated
}

enum RoomType {
  org      // Organization-wide chat
  team     // Team-specific chat
  dm       // Direct message between two users
  incident // Incident room (future use)
}

enum MessageType {
  text
  image
  audio
}

enum InviteStatus {
  pending
  accepted
  expired
}

// Organization model - central to multi-tenant architecture
model Organization {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  logo        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  users       User[]
  teams       Team[]
  incidents   Incident[]
  inviteTokens InviteToken[]
  rooms       Room[]
}

model User {
  id              String    @id @default(uuid())
  fullName        String
  email           String    @unique
  phoneNumber     String?
  password        String
  role            Role      @default(employee)
  profileImage    String?
  emailVerified   Boolean   @default(false)
  phoneVerified   Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Organization relation
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  createdIncidents    Incident[]    @relation("CreatedIncidents")
  managedIncidents    Incident[]    @relation("ManagedIncidents")
  incidentLogs        IncidentLog[]
  incidentAttachments IncidentAttachment[]
  messages            Message[]
  teamMembers         TeamMember[]
  otpVerifications    OTPVerification[]
  sentInvites         InviteToken[] @relation("UserSentInvites")
  createdRooms        Room[]
  roomParticipants    RoomParticipant[]
}

model Team {
  id              String    @id @default(uuid())
  name            String
  description     String?
  createdAt       DateTime  @default(now())

  // Organization relation
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  members         TeamMember[]
  inviteTokens    InviteToken[] // Invites associated with this team
  
  // Incidents
  sourceIncidents     Incident[] @relation("SourceIncidents")
  assignedIncidents   Incident[] @relation("AssignedIncidents")
  
  // Rooms
  rooms               Room[]
}

model TeamMember {
  id        String    @id @default(uuid())
  joinedAt  DateTime  @default(now())

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  teamId    String
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model Incident {
  id              String            @id @default(uuid())
  title           String
  description     String?
  category        IncidentCategory  @default(incident)
  priority        IncidentPriority  @default(medium)
  status          IncidentStatus    @default(open)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  resolvedAt      DateTime?
  closedAt        DateTime?

  // Organization relation
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Reporter
  createdById     String
  createdBy       User              @relation("CreatedIncidents", fields: [createdById], references: [id])

  // Source team (where issue originated)
  sourceTeamId    String
  sourceTeam      Team              @relation("SourceIncidents", fields: [sourceTeamId], references: [id])

  // Assigned team (responsible for resolving)
  assignedTeamId  String?
  assignedTeam    Team?             @relation("AssignedIncidents", fields: [assignedTeamId], references: [id])

  // Assigned manager
  assignedManagerId String?
  assignedManager User?             @relation("ManagedIncidents", fields: [assignedManagerId], references: [id])

  // Relations
  logs            IncidentLog[]
  rooms           Room[]
  attachments     IncidentAttachment[]

  @@index([organizationId])
  @@index([status])
  @@index([priority])
  @@index([sourceTeamId])
  @@index([assignedTeamId])
  @@index([assignedManagerId])
  @@index([createdById])
}

model IncidentLog {
  id              String          @id @default(uuid())
  incidentId      String
  incident        Incident        @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  actorId         String
  actor           User            @relation(fields: [actorId], references: [id], onDelete: Cascade)

  action          IncidentLogAction
  oldValue        String?
  newValue        String?
  message         String?
  createdAt       DateTime        @default(now())

  @@index([incidentId])
  @@index([actorId])
  @@index([createdAt])
}

model Room {
  id              String    @id @default(uuid())
  name            String
  type            RoomType
  organizationId  String
  teamId          String?   // For team rooms
  incidentId      String?   // For incident rooms (future)
  createdById     String?
  isArchived      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team            Team?        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  incident        Incident?    @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  createdBy       User?        @relation(fields: [createdById], references: [id])

  messages        Message[]
  participants    RoomParticipant[]

  @@index([organizationId])
  @@index([teamId])
  @@index([incidentId])
  @@index([type])
}

model RoomParticipant {
  id          String    @id @default(uuid())
  roomId      String
  userId      String
  joinedAt    DateTime  @default(now())
  role        String?   // Optional: 'admin', 'member'
  lastReadAt  DateTime? // Optional: track last read timestamp

  // Relations
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model Message {
  id          String      @id @default(uuid())
  roomId      String
  senderId    String
  content     String      @default("")
  type        MessageType @default(text)
  mediaUrl    String?     // URL for image/audio files
  mimeType    String?     // e.g. "image/png", "audio/webm"
  duration    Int?        // Audio duration in seconds
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  editedAt    DateTime?
  isDeleted   Boolean     @default(false)

  // Relations
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender      User      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([senderId])
  @@index([createdAt])
}

// Invite token model for manager/employee onboarding
model InviteToken {
  id              String        @id @default(uuid())
  token           String        @unique
  email           String
  role            Role
  status          InviteStatus  @default(pending)
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  acceptedAt      DateTime?
  welcomeMessage  String?       // Optional welcome message for invitee

  // Organization relation
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Team relation (optional - for team-specific invites)
  teamId          String?
  team            Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // Invited by (admin or manager who created the invite)
  invitedById     String?
  invitedBy       User?         @relation("UserSentInvites", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([invitedById])
  @@index([teamId])
}

// Evidence images attached to incidents (pending review or active)
model IncidentAttachment {
  id            String    @id @default(uuid())
  incidentId    String
  incident      Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  uploadedById  String
  uploadedBy    User      @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  fileUrl       String
  fileType      String    // e.g. "image/png"
  fileName      String?
  fileSize      Int?
  createdAt     DateTime  @default(now())

  @@index([incidentId])
  @@index([uploadedById])
}

// OTP verification model for phone verification
model OTPVerification {
  id          String    @id @default(uuid())
  phoneNumber String
  otp         String
  expiresAt   DateTime
  verified    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  // User relation
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneNumber, otp])
  @@index([userId])
}